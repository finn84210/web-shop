@page "/Producten/{id:int}"
@model ProductDetailsModel
@{
    ViewData["Title"] = Model.Product.Name;
}

<section class="product-detail">
    <div class="product-detail-media">
        <span>@Model.Product.Name.Substring(0, 1)</span>
    </div>

    <article class="product-detail-content">
        <a class="back-link" asp-page="/Bestellen">Terug naar producten</a>
        <span class="category-pill">@Model.Product.Category</span>
        <h1>@Model.Product.Name</h1>
        <p class="lead">@Model.Product.Description</p>

        <div class="product-detail-buy">
            <strong>@Model.Product.Price.ToString("C")</strong>
            <span>@Model.Product.Stock op voorraad</span>
        </div>

        <div class="product-detail-actions">
            @if (Model.Product.Stock > 0)
            {
                <button class="btn btn-primary btn-lg add-to-cart" type="button" data-product-id="@Model.Product.Id">In winkelmand</button>
            }
            else
            {
                <button class="btn btn-secondary btn-lg" type="button" disabled>Uitverkocht</button>
            }
            <a class="btn btn-outline-dark btn-lg" asp-page="/Winkelmandje">Bekijk winkelmand</a>
        </div>
    </article>
</section>
